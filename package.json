{
  "name": "yunxiao-cli",
  "version": "0.3.0",
  "description": "Aliyun Yunxiao (云效) command-line tool for workitem, comment, config and pipeline management",
  "keywords": [
    "yunxiao",
    "cli",
    "devops",
    "aliyun",
    "projex",
    "workitem",
    "云效"
  ],
  "homepage": "https://github.com/ericshao/yunxiao-cli#readme",
  "bugs": {
    "url": "https://github.com/ericshao/yunxiao-cli/issues"
  },
  "license": "MIT",
  "author": "C2Cloud Team",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "yunxiao": "./bin/yunxiao",
    "yx": "./bin/yunxiao"
  },
  "files": [
    "bin",
    "dist",
    "completions",
    "README.md",
    "QUICKSTART.md",
    "AGENTS.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ericshao/yunxiao-cli.git"
  },
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc --project tsconfig.build.json",
    "build:watch": "tsc --project tsconfig.build.json --watch",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "prepack": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "completions": "node scripts/generate-completions.js",
    "prepublishOnly": "npm run test && npm run build && npm run completions"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.3",
    "commander": "^11.1.0",
    "conf": "^11.0.2",
    "dayjs": "^1.11.10",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.2.12",
    "ora": "^5.4.1",
    "update-notifier": "^7.0.0",
    "wrap-ansi": "^8.1.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@types/update-notifier": "^6.0.8",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
